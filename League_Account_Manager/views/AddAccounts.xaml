<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="League_Account_Manager.views.AddAccounts"
    mc:Ignorable="d"
    d:DesignHeight="749" d:DesignWidth="1216"
    Title="AddAccounts">

    <Grid Background="Transparent" Margin="0,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" Padding="12" Background="#FF3A3A3A" CornerRadius="8" BorderBrush="#FF4C4C4C"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Add accounts" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Margin="12,0,0,0" Text="Add single accounts or import multiple at once."
                           Foreground="#CCFFFFFF" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0,12,8,0" Padding="12" Background="#FF2F2F2F"
                CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Single account" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Label Content="Username" Foreground="White" />
                    <ui:TextBox x:Name="Username" MinWidth="300" Width="300" MaxLines="1" />
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Label Content="Password" Foreground="White" />
                    <ui:PasswordBox x:Name="Password" MinWidth="300" Width="300" MaxLines="1" />
                </StackPanel>
                <ui:Button Grid.Row="3" Margin="0,16,0,0" Content="Add account" Height="40" Width="160"
                           Click="Button_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="8,12,0,0" Padding="12" Background="#FF2F2F2F"
                CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Bulk import" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Grid.Row="1" Text="Paste accounts (username:password) one per line." Foreground="#CCFFFFFF"
                           Margin="0,6,0,8" TextWrapping="Wrap" />
                <ui:TextBox Grid.Row="2" x:Name="BulkInput" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="140"
                            VerticalScrollBarVisibility="Auto"
                            Background="#FF1E1E1E" Foreground="White" />
                <ui:Button Grid.Row="3" Margin="0,12,0,0" Content="Add all" Height="48" Width="200" FontSize="16"
                           Click="Button_Click_1" />
            </Grid>
        </Border>

    </Grid>
</Page>