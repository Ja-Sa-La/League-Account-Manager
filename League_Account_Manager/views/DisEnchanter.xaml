<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="League_Account_Manager.views.DisEnchanter"
    mc:Ignorable="d"
    d:DesignHeight="749" d:DesignWidth="1216"
    Title="DisEnchanter">

    <Grid Background="Transparent" Margin="0,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" Padding="12" Background="#FF3A3A3A" CornerRadius="8" BorderBrush="#FF4C4C4C"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button Content="Disenchant selected" Height="40" Width="170" Click="ButtonBase_OnClick1" />
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="Select all champs" Height="40" Width="150"
                           Click="SelectChamps" />
                <ui:Button Grid.Column="2" Margin="8,0,0,0" Content="Select all skins" Height="40" Width="150"
                           Click="SelectSkins" />
                <StackPanel Grid.Column="4" Orientation="Vertical" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Label Content="Blue essense to be gained: 0" Name="belabel" Foreground="White" />
                    <Label Content="Orange essense to be gained: 0" Name="oelabel" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0,12,8,0" Padding="12" Background="#FF2F2F2F"
                CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White" Text="Blue essence sources" />
                <ListBox SelectionChanged="ChampLootTable_OnSelectionChanged" Name="ChampLootTable" Grid.Row="1"
                         SelectionMode="Multiple" Padding="4" BorderBrush="#FF4C4C4C" BorderThickness="1"
                         Background="#FF202020" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal" ItemWidth="200" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Margin" Value="6" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" BorderBrush="#FF4C4C4C" BorderThickness="1"
                                                CornerRadius="6" Background="#FF303030">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF7FA8FF" />
                                                <Setter TargetName="Bd" Property="Background" Value="#FF3B3B3B" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF5A5A5A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="180" Padding="8" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="56" Height="56" CornerRadius="4" ClipToBounds="True"
                                            BorderBrush="#2D333B" BorderThickness="1">
                                        <Image Source="{Binding IconUrl}" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Value}" FontSize="12" Foreground="#9AA4B1" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="8,12,0,0" Padding="12" Background="#FF2F2F2F"
                CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Orange essence sources" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                <ListBox SelectionChanged="ChampLootTable_OnSelectionChanged" x:Name="SkinLootTable" Grid.Row="1"
                         SelectionMode="Multiple" Padding="4" BorderBrush="#FF4C4C4C" BorderThickness="1"
                         Background="#FF202020" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal" ItemWidth="200" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Margin" Value="6" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" BorderBrush="#FF4C4C4C" BorderThickness="1"
                                                CornerRadius="6" Background="#FF303030">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF7FA8FF" />
                                                <Setter TargetName="Bd" Property="Background" Value="#FF3B3B3B" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF5A5A5A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="180" Padding="8" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="56" Height="56" CornerRadius="4" ClipToBounds="True"
                                            BorderBrush="#2D333B" BorderThickness="1">
                                        <Image Source="{Binding IconUrl}" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Value}" FontSize="12" Foreground="#9AA4B1" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

    </Grid>
</Page>