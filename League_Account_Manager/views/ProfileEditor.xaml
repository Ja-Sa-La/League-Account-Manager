<Page x:Class="League_Account_Manager.views.ProfileEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="749" d:DesignWidth="1216"
      Title="ProfileEditor" Loaded="OnProfileEditorLoaded" Unloaded="OnProfileEditorUnloaded">

    <Grid>
        <ui:Button Content="Disable Chat" Margin="10,15,0,0" Click="OnDisableChatClick" VerticalAlignment="Top"
                   Height="77"
                   Width="168" />
        <ui:Button Content="Enable Chat" Margin="10,102,0,0" Click="OnEnableChatClick" VerticalAlignment="Top"
                   Height="78"
                   Width="168" />
        <ui:Button Content="Get Chat settings" Margin="1011,15,0,0" Click="OnGetChatSettingsClick"
                   VerticalAlignment="Top"
                   Height="77" Width="169" Visibility="Hidden" />
        <ui:Button Content="Set Chat Statusmessage" Margin="185,15,0,0" Click="OnSetStatusMessageClick"
                   VerticalAlignment="Top"
                   Height="77" Width="311" />
        <ui:Button Content="Show Offline" Margin="10,190,0,0" Click="OnSetChatOfflineClick" VerticalAlignment="Top"
                   Height="77"
                   Width="168" />
        <ui:Button Content="Show Away" Margin="10,277,0,0" Click="OnSetChatAwayClick" VerticalAlignment="Top"
                   Height="77"
                   Width="168" />
        <ui:Button Content="Show Mobile" Margin="10,364,0,0" Click="OnSetChatMobileClick" VerticalAlignment="Top"
                   Height="78"
                   Width="168" />
        <ui:Button Content="Show Online" Margin="10,452,0,0" Click="OnSetChatOnlineClick" VerticalAlignment="Top"
                   Height="77"
                   Width="168" />
        <ui:Button Content="set Icon" Margin="501,15,0,0" Click="OnSetIconClick" VerticalAlignment="Top" Height="77"
                   Width="250" />
        <ui:TextBox ClearButtonEnabled="False" PlaceholderText="Status message" AcceptsReturn="True"
                    Margin="185,102,0,220" TextWrapping="Wrap"
                    Name="StatusMessageContainer" FontSize="11"
                    Text="" HorizontalAlignment="Left" Width="311" MinWidth="311" />
        <ui:AutoSuggestBox IsEnabled="False" PlaceholderText="Loading!" MaxWidth="250" Margin="504,102,0,0"
                           Name="IconList" VerticalAlignment="Top" Width="245"
                           SuggestionChosen="OnIconSuggestionChosen" GotFocus="OnIconListGotFocus"
                           HorizontalAlignment="Left">
            <ui:AutoSuggestBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel LastChildFill="True">
                        <Border Width="28" Height="28" CornerRadius="4" ClipToBounds="True" DockPanel.Dock="Left">
                            <Image Source="{Binding IconUrl}" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </DockPanel>
                </DataTemplate>
            </ui:AutoSuggestBox.ItemTemplate>
        </ui:AutoSuggestBox>
        <Border Margin="504,143,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="245" Height="245"
                BorderBrush="#FF4C4C4C" BorderThickness="1" CornerRadius="6">
            <Image x:Name="IconPreview" Stretch="UniformToFill" />
        </Border>
        <ui:Button Content="set Background" Click="OnSetBackgroundClick" VerticalAlignment="Top" Height="77"
                   Width="250"
                   Margin="756,15,0,0" />
        <ui:AutoSuggestBox IsEnabled="False" PlaceholderText="Loading!" MaxWidth="250" x:Name="SkinList"
                           VerticalAlignment="Top" SuggestionChosen="OnSkinSuggestionChosen"
                           GotFocus="OnIconListGotFocus" Margin="761,102,0,0"
                           HorizontalAlignment="Left" Width="245">
            <ui:AutoSuggestBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel LastChildFill="True">
                        <Border Width="44" Height="28" CornerRadius="4" ClipToBounds="True" DockPanel.Dock="Left">
                            <Image Source="{Binding IconUrl}" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </DockPanel>
                </DataTemplate>
            </ui:AutoSuggestBox.ItemTemplate>
        </ui:AutoSuggestBox>
        <Border Margin="761,143,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="245" Height="173"
                BorderBrush="#FF4C4C4C" BorderThickness="1" CornerRadius="6">
            <Image x:Name="SkinPreview" Stretch="UniformToFill" />
        </Border>
        <ui:Button Content="set Rank" Margin="761,414,0,0" Click="OnSetRankClick" VerticalAlignment="Top" Height="76"
                   Width="250" />
        <ComboBox Margin="506,417,0,0" ItemsSource="{Binding QueueList}" Name="Mode" VerticalAlignment="Top"
                  HorizontalAlignment="Left" MinWidth="247" />
        <ComboBox Margin="506,488,0,0" ItemsSource="{Binding RankList}" Name="Rank" VerticalAlignment="Top"
                  HorizontalAlignment="Left" MinWidth="247" />
        <ComboBox Margin="506,560,0,0" ItemsSource="{Binding TierList}" Name="Division" HorizontalAlignment="Left"
                  MinWidth="247" VerticalAlignment="Top" />
        <Label Content="Queue" HorizontalAlignment="Left" Margin="506,393,0,0" VerticalAlignment="Top" Height="24"
               Width="245" />
        <Label Content="Rank" HorizontalAlignment="Left" Margin="506,459,0,0" VerticalAlignment="Top" Height="24"
               Width="245" />
        <Label Content="Division" HorizontalAlignment="Left" Margin="506,530,0,0" VerticalAlignment="Top" Height="24"
               Width="245" />


    </Grid>
</Page>