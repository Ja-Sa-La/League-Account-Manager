<Page

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="League_Account_Manager.views.ValorantAccounts"
    mc:Ignorable="d"
    d:DesignHeight="749" d:DesignWidth="1216"
    Title="Valorant Accounts"
    ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

    <Grid Margin="0,0,10,10" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="#FF3A3A3A" CornerRadius="8" BorderBrush="#FF4C4C4C"
                Margin="10,10,10,265" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <WrapPanel ItemHeight="40" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Width="260" Margin="0,0,0,6">
                            <TextBlock Text="Valorant account dashboard" FontSize="16" FontWeight="SemiBold"
                                       Foreground="White" Width="260" />
                            <TextBlock Text="Manage Valorant account data." FontSize="10" Foreground="#CCFFFFFF" />
                        </StackPanel>
                        <ui:Button Margin="4" Padding="6,1" x:Name="killleague" Content="Kill client" FontSize="12"
                                   Click="OnKillClientClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="openleague1" Content="Open League" FontSize="12"
                                   Click="OnOpenValorantClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="PullData" Content="PullData" FontSize="12"
                                   Click="OnPullDataClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="Delete" Content="Delete" FontSize="12"
                                   Click="OnDeleteClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="Login" Content="Login" FontSize="12"
                                   Click="OnLoginClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="StealthLogin" Content="Stealth Login" FontSize="12"
                                   Click="OnLoginClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="DuplicateRemover" Content="Remove duplicates"
                                   FontSize="10"
                                   Click="OnRemoveDuplicatesClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="NameChangeButton" Content="Name Change"
                                   FontSize="12"
                                   Click="OnNameChangeClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="GenerateLoginToken" Content="Generate token"
                                   FontSize="12"
                                   Click="GenerateLoginToken_OnClick" Width="130" />
                        <ui:Button Margin="4" Padding="6,1" x:Name="UseLoginToken" Content="Login With token"
                                   FontSize="12"
                                   Click="UseLoginToken_OnClick" Width="130" />

                    </WrapPanel>
                    <ui:TextBox x:Name="FilterTextBox" Margin="870,50,62,0"
                                PlaceholderText="Agent, skin, title, or server name"
                                TextWrapping="NoWrap" Padding="8,6" FontSize="12"
                                TextChanged="OnFilterTextChanged" VerticalAlignment="Top" />
                </Grid>
            </Grid>
        </Border>

        <Grid Height="605" Margin="10,124,10,0" VerticalAlignment="Top" Grid.RowSpan="2">
            <Border Background="#FF2F2F2F" CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1">
                <DataGrid x:Name="ValorantAccountsDataGrid" SelectionUnit="FullRow"
                          KeyDown="OnAccountsKeyDown"
                          MouseLeftButtonDown="OnAccountsMouseLeftButtonDown"
                          IsReadOnly="True"
                          HorizontalContentAlignment="Stretch" AutoGenerateColumns="False"
                          SelectionMode="Single" Background="#FF202020" BorderBrush="#FF4C4C4C" Margin="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn MaxWidth="220" Header="Username" Width="*" Binding="{Binding username}" />
                        <DataGridTextColumn MaxWidth="250" Header="Password" Width="*" Binding="{Binding password}" />
                        <DataGridTextColumn MaxWidth="250" Header="RiotID" Width="*" Binding="{Binding riotID}" />
                        <DataGridTextColumn MinWidth="60" Header="Server" Binding="{Binding valorantServer}" />
                        <DataGridTextColumn MinWidth="60" Header="Level" Binding="{Binding valorantLevel}" />
                        <DataGridTextColumn MinWidth="80" Header="Rank" Binding="{Binding valorantRank}" />
                        <DataGridTextColumn Width="Auto" MinWidth="50" Header="VP" Binding="{Binding valorantVp}" />
                        <DataGridTextColumn Width="Auto" MinWidth="50" Header="RP" Binding="{Binding valorantRp}" />
                        <DataGridTextColumn Width="Auto" MinWidth="50" Header="KC" Binding="{Binding valorantKc}" />
                        <DataGridTextColumn Width="Auto" MinWidth="80" Header="Agents"
                                            Binding="{Binding ValorantAgentsCount}" />
                        <DataGridTextColumn Width="Auto" MinWidth="80" Header="Contracts"
                                            Binding="{Binding ValorantContractsCount}" />
                        <DataGridTextColumn Width="Auto" MinWidth="80" Header="Sprays"
                                            Binding="{Binding ValorantSpraysCount}" />
                        <DataGridTextColumn Width="Auto" MinWidth="90" Header="Gun Buddies"
                                            Binding="{Binding ValorantGunBuddiesCount}" />
                        <DataGridTextColumn Width="Auto" MinWidth="80" Header="Cards"
                                            Binding="{Binding ValorantCardsCount}" />
                        <DataGridTextColumn Width="Auto" MinWidth="80" Header="Skins"
                                            Binding="{Binding ValorantSkinsCount}" />
                        <DataGridTextColumn Width="Auto" MinWidth="80" Header="Titles"
                                            Binding="{Binding ValorantTitlesCount}" />
                        <DataGridTextColumn MinWidth="50" Header="Notes">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Open" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>

                    <DataGrid.Resources>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Style.Triggers>
                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF313131" />
                                    <Setter Property="BorderBrush" Value="#FF313131" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                        </Style>

                    </DataGrid.Resources>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>