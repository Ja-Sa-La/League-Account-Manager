<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="League_Account_Manager.views.ChampionSelect"
    mc:Ignorable="d"
    d:DesignHeight="749" d:DesignWidth="1216"
    Title="ChampionSelect">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="#FF3A3A3A" CornerRadius="8" BorderBrush="#FF4C4C4C"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Team scouting" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Fill player names, open stats sites, and view ranks." Foreground="#CCFFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Pull info" Click="OnPullTeamInfoClick" Height="40" Width="110" Margin="4,0,0,0" />
                    <Button Content="Open multi.op.gg" Click="OnOpenMultiOpGgClick" Height="40" Width="150"
                            Margin="4,0,0,0" />
                    <Button Content="DODGE" Click="OnDodgeClick" Height="40" Width="100" Margin="4,0,0,0" />
                    <Button Content="Open PoroProfessor" Click="OnOpenPoroProfessorClick" Height="40" Width="160"
                            Margin="4,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Player inputs -->
            <Border Grid.Column="0" Background="#FF2F2F2F" CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1"
                    Padding="12" Margin="0,0,8,0">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="360" ItemHeight="120" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Resources>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FF303030" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="BorderBrush" Value="#FF4C4C4C" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="10" />
                            <Setter Property="Margin" Value="6" />
                        </Style>
                    </ItemsControl.Resources>
                    <ItemsControl.Items>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Player 1" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                    <ui:TextBox Name="Player1" MinWidth="180" MaxWidth="200" Text="Player Name" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Name="opgg1" Content="Open op.gg" Click="OnOpenOpGgClick" Height="32"
                                            Width="120" Margin="0,0,0,6" />
                                    <Button Name="leagueofgraphs1" Content="Open League of Graphs"
                                            Click="OnOpenLeagueOfGraphsClick" Height="32" Width="140" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Player 2" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                    <ui:TextBox x:Name="Player2" MinWidth="180" MaxWidth="200" Text="Player Name" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Name="opgg2" Content="Open op.gg" Click="OnOpenOpGgClick" Height="32"
                                            Width="120" Margin="0,0,0,6" />
                                    <Button Name="leagueofgraphs2" Content="Open League of Graphs"
                                            Click="OnOpenLeagueOfGraphsClick" Height="32" Width="140" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Player 3" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                    <ui:TextBox x:Name="Player3" MinWidth="180" MaxWidth="200" Text="Player Name" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Name="opgg3" Content="Open op.gg" Click="OnOpenOpGgClick" Height="32"
                                            Width="120" Margin="0,0,0,6" />
                                    <Button Name="leagueofgraphs3" Content="Open League of Graphs"
                                            Click="OnOpenLeagueOfGraphsClick" Height="32" Width="140" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Player 4" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                    <ui:TextBox x:Name="Player4" MinWidth="180" MaxWidth="200" Text="Player Name" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Name="opgg4" Content="Open op.gg" Click="OnOpenOpGgClick" Height="32"
                                            Width="120" Margin="0,0,0,6" />
                                    <Button Name="leagueofgraphs4" Content="Open League of Graphs"
                                            Click="OnOpenLeagueOfGraphsClick" Height="32" Width="140" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Player 5" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                    <ui:TextBox x:Name="Player5" MinWidth="180" MaxWidth="200" Text="Player Name" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Name="opgg5" Content="Open op.gg" Click="OnOpenOpGgClick" Height="32"
                                            Width="120" Margin="0,0,0,6" />
                                    <Button Name="leagueofgraphs5" Content="Open League of Graphs"
                                            Click="OnOpenLeagueOfGraphsClick" Height="32" Width="140" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ItemsControl.Items>
                </ItemsControl>
            </Border>

            <!-- Player info cards -->
            <Border Grid.Column="1" Background="#FF2F2F2F" CornerRadius="8" BorderBrush="#FF4C4C4C" BorderThickness="1"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Ranks &amp; stats" FontSize="16" FontWeight="SemiBold" Foreground="White"
                               Margin="0,0,0,8" />
                    <ItemsControl x:Name="RanksList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="1" Rows="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Resources>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FF303030" />
                                <Setter Property="CornerRadius" Value="8" />
                                <Setter Property="BorderBrush" Value="#FF4C4C4C" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Padding" Value="8" />
                                <Setter Property="Margin" Value="4" />
                            </Style>
                        </ItemsControl.Resources>
                        <ItemsControl.Items>
                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Player 1" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock Grid.Row="1" Text="Peak rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="1" Margin="90,0,0,0" Name="player1peak" />
                                    <TextBlock Grid.Row="2" Text="Current rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="2" Margin="90,0,0,0" Name="player1rank" />
                                    <TextBlock Grid.Row="3" Text="Winrate / KDA:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="3" Margin="110,0,0,0" Name="player1wr" />
                                </Grid>
                            </Border>
                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Player 2" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock Grid.Row="1" Text="Peak rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="1" Margin="90,0,0,0" Name="player2peak" />
                                    <TextBlock Grid.Row="2" Text="Current rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="2" Margin="90,0,0,0" Name="player2rank" />
                                    <TextBlock Grid.Row="3" Text="Winrate / KDA:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="3" Margin="110,0,0,0" Name="player2wr" />
                                </Grid>
                            </Border>
                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Player 3" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock Grid.Row="1" Text="Peak rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="1" Margin="90,0,0,0" Name="player3peak" />
                                    <TextBlock Grid.Row="2" Text="Current rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="2" Margin="90,0,0,0" Name="player3rank" />
                                    <TextBlock Grid.Row="3" Text="Winrate / KDA:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="3" Margin="110,0,0,0" Name="player3wr" />
                                </Grid>
                            </Border>
                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Player 4" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock Grid.Row="1" Text="Peak rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="1" Margin="90,0,0,0" Name="player4peak" />
                                    <TextBlock Grid.Row="2" Text="Current rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="2" Margin="90,0,0,0" Name="player4rank" />
                                    <TextBlock Grid.Row="3" Text="Winrate / KDA:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="3" Margin="110,0,0,0" Name="player4wr" />
                                </Grid>
                            </Border>
                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Player 5" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock Grid.Row="1" Text="Peak rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="1" Margin="90,0,0,0" Name="player5peak" />
                                    <TextBlock Grid.Row="2" Text="Current rank:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="2" Margin="90,0,0,0" Name="player5rank" />
                                    <TextBlock Grid.Row="3" Text="Winrate / KDA:" Foreground="#CCFFFFFF" />
                                    <TextBlock Grid.Row="3" Margin="110,0,0,0" Name="player5wr" />
                                </Grid>
                            </Border>
                        </ItemsControl.Items>
                    </ItemsControl>
                    <TextBlock Text="Ranked winrate and KDA are from the last 40 games." Foreground="#FFB5B5B5"
                               TextWrapping="Wrap" Margin="4,8,4,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>