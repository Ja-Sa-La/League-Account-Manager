<Page x:Class="League_Account_Manager.views.SettingsEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SettingsEditor">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="DynamicTabControl" Grid.Row="0" Margin="0,0,0,50" />

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10">
                <Button Content="Reset" Click="OnResetClick" Margin="5" />
                <Button Content="Export" Click="OnExportClick" Margin="5" />
                <Button Content="Import" Click="OnImportClick" Margin="5" />
                <Button Content="Apply to Client" Click="OnApplyToClientClick" Margin="5" />
                <Button Content="Apply to Account" Click="OnApplyToAccountClick" Margin="5" />
                <Button Content="Lock" Click="OnLockClick" Margin="5" />
                <Button Content="Unlock" Click="OnUnlockClick" Margin="5" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>