<Window x:Class="League_Account_Manager.Windows.DisplayDataWithSearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" Height="620"
        Width="560" WindowStyle="None" WindowStartupLocation="CenterScreen" Background="#FF1F1F1F"
        MouseDown="Window_MouseDownDatadisplay" Deactivated="Window_Deactivated" ResizeMode="NoResize">
    <Grid Background="#FF1F1F1F" Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF3A3A3A" BorderBrush="#FF4C4C4C" BorderThickness="1" Padding="10"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Data viewer" Foreground="White" FontSize="16" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FF2F2F2F" BorderBrush="#FF4C4C4C" BorderThickness="1" Padding="8"
                Margin="0,8,0,8" CornerRadius="6">
            <ui:TextBox TextAlignment="Left" VerticalContentAlignment="Center"
                        TextWrapping="NoWrap" Name="datafiltersearch" PlaceholderText="Search"
                        TextChanged="TextBox_TextChangeddatafilt" />
        </Border>

        <Border Grid.Row="2" Background="#FF2A2A2A" BorderBrush="#FF4C4C4C" BorderThickness="1" CornerRadius="6"
                Padding="8" Margin="0,0,0,8">
            <ScrollViewer MouseDown="Window_MouseDownDatadisplay" VerticalScrollBarVisibility="Auto">
                <ItemsControl Name="ItemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FF323232" CornerRadius="6" Padding="10" Margin="0,8,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon placeholder and image -->
                                    <Grid>
                                        <Border Height="60" MinWidth="60" Background="#FF454545" CornerRadius="4"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Image Height="60" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                   Stretch="Uniform" Source="{Binding IconSource}" />
                                        </Border>
                                    </Grid>

                                    <!-- Item text and optional price -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="White" TextWrapping="Wrap"
                                                   FontSize="16" />
                                        <TextBlock Text="{Binding Price}" Foreground="#FFB0B0B0" FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>