<Window x:Class="League_Account_Manager.Windows.PasswordPrompt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account File Password"
        Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FF1F1F1F"
        MouseDown="Window_MouseDown"
        Topmost="True">
    <Grid Background="#FF1F1F1F" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF3A3A3A" BorderBrush="#FF4C4C4C" BorderThickness="1" Padding="10"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Account file password" Foreground="White" FontSize="16" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FF2A2A2A" BorderBrush="#FF4C4C4C" BorderThickness="1" CornerRadius="6"
                Padding="12" Margin="0,8,0,8">
            <StackPanel>
                <TextBlock x:Name="PromptText"
                           Text="Enter the account file password:"
                           Foreground="White"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           FontSize="13" />

                <PasswordBox x:Name="PasswordBox"
                             Background="#FF1F1F1F"
                             BorderBrush="#FF4C4C4C"
                             Foreground="White"
                             CaretBrush="White"
                             Padding="8"
                             FontSize="13" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="90" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"
                    Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF4C4C4C" Padding="8,4" />
            <Button Content="Cancel" Width="90" IsCancel="True" Click="Cancel_Click"
                    Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF4C4C4C" Padding="8,4" />
        </StackPanel>
    </Grid>
</Window>