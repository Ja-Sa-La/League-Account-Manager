<Window x:Class="League_Account_Manager.Windows.NoteDisplay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="460"
        Width="420" WindowStyle="None" WindowStartupLocation="CenterScreen" Background="#FF1F1F1F"
        MouseDown="Window_MouseDownDatadisplay"
        Deactivated="Window_Deactivated"
        Closing="Window_Closing"
        ResizeMode="NoResize">
    <Grid Background="#FF1F1F1F" Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF3A3A3A" BorderBrush="#FF4C4C4C" BorderThickness="1" Padding="10"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Notes" Foreground="White" FontSize="16" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FF2A2A2A" BorderBrush="#FF4C4C4C" BorderThickness="1" CornerRadius="6"
                Padding="8" Margin="0,8,0,8">
            <TextBox MouseDown="Window_MouseDownDatadisplay"
                     Name="Datathing" Margin="0"
                     TextWrapping="Wrap" Text=""
                     IsEnabled="True" IsReadOnly="False" VerticalScrollBarVisibility="Visible"
                     IsManipulationEnabled="True"
                     IsInactiveSelectionHighlightEnabled="True"
                     AcceptsReturn="True" />
        </Border>
    </Grid>
</Window>